# ================================
# 1. Skapa NER-pipeline (en per GPU/process)
# ================================
from transformers import AutoTokenizer, AutoModelForTokenClassification

def create_ner_pipeline(device: int, model_name: str = "dslim/bert-base-NER", fp16: bool = True):
    """
    Skapar model+tokenizer för token-classification på angiven GPU.
    Vi kör inferens manuellt (snabbare än pipeline när du chunkar/batchar).
    """
    print(f"[GPU {device}] Laddar tokenizer+modell ({model_name}) ...")

    tokenizer = AutoTokenizer.from_pretrained(model_name, use_fast=True)
    torch_dtype = torch.float16 if (fp16 and torch.cuda.is_available()) else None

    model = AutoModelForTokenClassification.from_pretrained(model_name, torch_dtype=torch_dtype)
    model.to(f"cuda:{device}")
    model.eval()

    print(f"[GPU {device}] Modell laddad. fp16={bool(torch_dtype)}")
    return {"tokenizer": tokenizer, "model": model, "device": device, "fp16": fp16}

from pathlib import Path
import torch

class YearWalk:
    """
    Kör NER på en fil genom att:
    1) tokenisera hela texten
    2) dela upp i overlappande chunkar (overflow)
    3) batcha inferens på GPU
    4) extrahera LOC via offsets tillbaka till originaltexten
    """

    def __init__(self, path: str, nlp, batch_size: int = 8, max_length: int = 384, stride: int = 64):
        self.path = path
        self.title = Path(path).name
        self.loclist = []
        self.errors = 0

        self.nlp = nlp
        self.batch_size = batch_size
        self.max_length = max_length
        self.stride = stride

        # interna buffers (för att slippa scope-problem)
        self._text = ""
        self._input_ids_list = None
        self._attention_mask_list = None
        self._offset_mapping_list = None

        self._run()

    def _tokenize(self, tokenizer):
        encodings = tokenizer(
            self._text,
            return_offsets_mapping=True,
            return_overflowing_tokens=True,
            truncation=True,
            max_length=self.max_length,
            stride=self.stride,
            padding=False,
        )
        self._input_ids_list = encodings["input_ids"]
        self._attention_mask_list = encodings["attention_mask"]
        self._offset_mapping_list = encodings["offset_mapping"]

    def _collate(self, tokenizer, device: int, batch_indices):
        # pad per batch
        max_len = max(len(self._input_ids_list[i]) for i in batch_indices)

        input_ids = []
        attention_mask = []
        offsets = []

        for i in batch_indices:
            ids = self._input_ids_list[i]
            am = self._attention_mask_list[i]
            off = self._offset_mapping_list[i]

            pad_len = max_len - len(ids)
            input_ids.append(ids + [tokenizer.pad_token_id] * pad_len)
            attention_mask.append(am + [0] * pad_len)
            offsets.append(off + [(0, 0)] * pad_len)

        input_ids = torch.tensor(input_ids, dtype=torch.long, device=f"cuda:{device}")
        attention_mask = torch.tensor(attention_mask, dtype=torch.long, device=f"cuda:{device}")
        return input_ids, attention_mask, offsets

    def _extract_locs(self, pred_ids, offsets, id2label):
        locs = []
        current = None  # [start, end]

        for pid, (s, e) in zip(pred_ids, offsets):
            if s == e:  # padding/special tokens
                continue

            label = id2label[int(pid)]

            if label.startswith("B-") and label.endswith("LOC"):
                if current is not None:
                    locs.append(self._text[current[0]:current[1]])
                current = [s, e]

            elif label.startswith("I-") and label.endswith("LOC"):
                if current is None:
                    current = [s, e]
                else:
                    current[1] = e

            else:
                if current is not None:
                    locs.append(self._text[current[0]:current[1]])
                    current = None

        if current is not None:
            locs.append(self._text[current[0]:current[1]])

        return locs

    def _run(self):
        # --- Läs text ---
        with open(self.path, "r", encoding="utf-8") as f:
            self._text = f.read()

        tokenizer = self.nlp["tokenizer"]
        model = self.nlp["model"]
        device = self.nlp["device"]
        use_fp16 = bool(self.nlp.get("fp16", True))

        # --- Tokenisera ---
        self._tokenize(tokenizer)

        # --- Inferens ---
        id2label = model.config.id2label

        try:
            with torch.no_grad():
                n_chunks = len(self._input_ids_list)

                for start in range(0, n_chunks, self.batch_size):
                    batch_indices = list(range(start, min(start + self.batch_size, n_chunks)))
                    input_ids, attention_mask, offsets_batch = self._collate(tokenizer, device, batch_indices)

                    if torch.cuda.is_available() and use_fp16:
                        with torch.autocast(device_type="cuda", dtype=torch.float16):
                            outputs = model(input_ids=input_ids, attention_mask=attention_mask)
                    else:
                        outputs = model(input_ids=input_ids, attention_mask=attention_mask)

                    predictions = outputs.logits.argmax(dim=-1).detach().cpu().tolist()

                    for pred_ids, offsets in zip(predictions, offsets_batch):
                        self.loclist.extend(self._extract_locs(pred_ids, offsets, id2label))

        except RuntimeError as e:
            self.errors += 1
            print(f"[ERROR] RuntimeError i fil {self.title}: {e}")


# ================================
# 3. Hjälpfunktioner för multi-GPU
# ================================
def chunk_list(lst, n):
    """
    Dela upp lst i n ungefär lika stora bitar.
    Om lst är kortare än n blir vissa chunkar tomma, vilket också är okej.
    """
    if n <= 0:
        return [lst]
    k = ceil(len(lst) / n) if len(lst) > 0 else 1
    return [lst[i:i + k] for i in range(0, len(lst), k)]


def worker_gpu(gpu_id: int, file_list, year: str, out_dir: str, batch_size: int = 64):
    """
    Körs i en separat process per GPU.
    - Laddar en NER-pipeline på (gpu_id)
    - Bearbetar alla filer i file_list
    - Skriver ut en partial-fil: {year}_gpu{gpu_id}.json
    """
    if len(file_list) == 0:
        print(f"[GPU {gpu_id}] Inga filer tilldelade, hoppar över.")
        return

    print(f"[GPU {gpu_id}] Startar worker med {len(file_list)} filer för år {year}")
    nlp = create_ner_pipeline(device=gpu_id)

    all_locs = []
    total_errors = 0

    for fpath in file_list:
        yw = YearWalk(fpath, nlp=nlp, batch_size=batch_size)
        all_locs.extend(yw.loclist)
        total_errors += yw.errors
        print(f"[GPU {gpu_id}] Klar med {Path(fpath).name}, errors={yw.errors}, locations={len(yw.loclist)}")

    out_dir = Path(out_dir).expanduser()
    out_dir.mkdir(parents=True, exist_ok=True)

    out_file = out_dir / f"{year}_gpu{gpu_id}.json"
    with out_file.open("w", encoding="utf-8") as f:
        json.dump(
            {"year": year, "gpu": gpu_id, "locs": all_locs, "errors": total_errors},
            f,
            ensure_ascii=False,
            indent=2
        )

    print(f"[GPU {gpu_id}] Klart! Skrev {out_file} (total locations: {len(all_locs)}, errors: {total_errors})")


def merge_outputs(year: str, out_dir: str = "~/ner_outputs", final_suffix: str = ""):
    """
    Slår ihop alla {year}_gpu*.json från out_dir till en enda fil {year}{final_suffix}.json.
    """
    out_dir = Path(out_dir).expanduser()
    locs = []
    total_errors = 0

    json_files = sorted(out_dir.glob(f"{year}_gpu*.json"))
    if not json_files:
        print(f"Inga partial-filer hittades för år {year} i {out_dir}")
        return

    for file in json_files:
        with file.open(encoding="utf-8") as f:
            data = json.load(f)
        locs.extend(data.get("locs", []))
        total_errors += data.get("errors", 0)

    final_name = f"{year}{final_suffix}.json" if final_suffix else f"{year}.json"
    final_path = out_dir / final_name
    with final_path.open("w", encoding="utf-8") as f:
        json.dump({"year": year, "locs": locs, "errors": total_errors}, f, ensure_ascii=False, indent=2)

    print(f"Slutresultat i {final_path}")
    print(f"Totalt locations: {len(locs)}, total errors: {total_errors}")


# ================================
# 4. Huvudflöde (multi-GPU körning)
# ================================
if __name__ == "__main__":
    # ----------------------------
    # Konfiguration
    # ----------------------------
    # Bas-katalog för ett år, t.ex. ~/Words/1866
    base_path = "~/Words/1866"   # ändra till din katalog
    out_dir = "~/ner_outputs"    # var NER-resultaten ska sparas
    batch_size = 64              # kan ökas om du har gott om GPU-minne

    # ----------------------------
    # Förbered
    # ----------------------------
    base_path = Path(base_path).expanduser()
    year = base_path.name  # "1866"

    # Hämta alla filer i katalogen
    files = [str(f) for f in base_path.iterdir() if f.is_file()]
    files = sorted(files)

    if not files:
        raise RuntimeError(f"Inga filer hittades i {base_path}")

    # Hur många GPUs har vi?
    available_gpus = torch.cuda.device_count()
    if available_gpus == 0:
        raise RuntimeError("Inga GPUs hittades. Kontrollera CUDA-installation & drivrutiner.")

    # Om du vill begränsa antal GPUs (t.ex. max 8):
    max_gpus = 8
    num_gpus = min(available_gpus, max_gpus)

    print(f"Hittade {len(files)} filer för år {year}")
    print(f"Använder {num_gpus} GPU(s) av {available_gpus} tillgängliga.")

    # Dela upp filerna i num_gpus chunkar
    file_chunks = chunk_list(files, num_gpus)

    # ----------------------------
    # Starta en process per GPU
    # ----------------------------
    procs = []
    for gpu_id, chunk in enumerate(file_chunks[:num_gpus]):
        p = Process(
            target=worker_gpu,
            args=(gpu_id, chunk, year, out_dir, batch_size)
        )
        p.start()
        procs.append(p)

    # Vänta tills alla processer är klara
    for p in procs:
        p.join()

    print("Alla worker-processer är klara.")

    # ----------------------------
    # Slå ihop partial-filer
    # ----------------------------
    merge_outputs(year=year, out_dir=out_dir)
