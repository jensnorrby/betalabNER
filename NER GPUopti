def parse_args():
    parser = argparse.ArgumentParser()

    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("--year", type=int)
    group.add_argument("--start-year", type=int)

    parser.add_argument("--end-year", type=int)
    parser.add_argument("--out-dir", type=str, default=str(OUT_DIR))
    parser.add_argument("--max-gpus", type=int, default=None)
    parser.add_argument("--fetch-threads", type=int, default=4)
    parser.add_argument("--batch-size", type=int, default=8)
    parser.add_argument("--max-length", type=int, default=384)
    parser.add_argument("--stride", type=int, default=64)
    parser.add_argument("--fp16", action="store_true")
    parser.add_argument("--cpu-only", action="store_true")
    parser.add_argument("--keep-partials", action="store_true")
    parser.add_argument("--limit-packages", type=int, default=None)

    args = parser.parse_args()

    if args.year is not None:
        args.years = [str(args.year)]
    else:
        if args.end_year is None:
            parser.error("--end-year krävs med --start-year")
        args.years = [str(y) for y in range(args.start_year, args.end_year + 1)]

    return args


def make_archive(password):
    return Archive(BETALAB_URL, auth=("demo", password))


def normalize_location(name):
    if not name:
        return None

    s = name.strip()
    s = re.sub(r"^[\s\.,;:!\?\)\]\}\'\"»«„“]+", "", s)
    s = re.sub(r"[\s\.,;:!\?\(\[\{\'\"»«„“]+$", "", s)
    s = re.sub(r"\s+", " ", s).strip()

    if not s:
        return None

    def fix_token(token):
        parts = token.split("-")
        return "-".join(
            p[:1].upper() + p[1:].lower() if p else p
            for p in parts
        )

    return " ".join(fix_token(tok) for tok in s.split(" "))


