DEFAULT_CREDENTIALS_PATH = Path("~/Betalab/api_credentials.txt").expanduser()
DEFAULT_OUT_DIR = Path("~/ner_outputs_direct").expanduser()

DEFAULT_MAX_LENGTH = 384
DEFAULT_STRIDE = 64
DEFAULT_BATCH_SIZE = 8
DEFAULT_FETCH_THREADS = 4

TITLE_LIST = [
    "Aftonbladet",
    "Dagens Nyheter",
    "Expressen",
    "Göteborgsposten",
    "Arbetet",
    "Göteborgs Handels- och Sjöfartstidning",
